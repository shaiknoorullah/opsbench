{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pnats.cloud/schemas/incident/recovery-plan.schema.json",
  "title": "RecoveryPlan",
  "description": "Output of recovery-planner. Each step is gated, ordered, verifiable, and rollback-able.",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "based_on_verdict_sha256", "steps", "prerequisites", "human_approval"],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^RP-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"
    },
    "based_on_verdict_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "verification"],
        "properties": {
          "description": { "type": "string" },
          "verification": { "type": "string" },
          "evidence_ref": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "action",
          "hypothesis_addressed",
          "risk",
          "rollback",
          "verification",
          "requires_human_approval"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^S[0-9]+$"
          },
          "action": { "type": "string", "minLength": 1 },
          "hypothesis_addressed": { "type": "string", "pattern": "^H[0-9]+(\\.[0-9]+)?$" },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high", "destructive"]
          },
          "rollback": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 },
          "requires_human_approval": { "type": "boolean" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^S[0-9]+$" }
          },
          "estimated_duration_min": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "human_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["pending", "approved", "denied", "edited"]
        },
        "approver": { "type": "string" },
        "approved_at_utc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "edits": { "type": "string" },
        "denial_reason": { "type": "string" }
      }
    }
  }
}
