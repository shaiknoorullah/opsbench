{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pnats.cloud/schemas/incident/timeline-entry.schema.json",
  "title": "TimelineEntry",
  "description": "One append-only entry in an incident timeline. Every causal claim must cite a sha256-sealed evidence file or be flagged verbal.",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp_utc", "category", "actor", "event", "evidence"],
  "properties": {
    "timestamp_utc": {
      "type": "string",
      "description": "ISO 8601 timestamp, UTC, with literal Z suffix. No local time, no offsets.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "category": {
      "type": "string",
      "enum": [
        "DETECTED",
        "RESPONSE_BEGAN",
        "QUARANTINE",
        "DISCOVERY",
        "COLLECTION_STARTED",
        "COLLECTION_COMPLETED",
        "ANALYSIS_STARTED",
        "ROUND_VERDICT",
        "HYPOTHESIS_VERDICT",
        "EVIDENCE_REQUESTED",
        "HUMAN_APPROVAL",
        "RECOVERY_BEGAN",
        "RECOVERY_STEP",
        "RECOVERY_COMPLETED",
        "COMMS_SENT",
        "EXTERNAL_EVENT",
        "ROLE_ASSIGNED",
        "SLA_BREACH",
        "CLOSED"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "description": "Human operator, agent name, or system component that performed the action."
    },
    "event": {
      "type": "string",
      "minLength": 1,
      "description": "Single concrete event. No editorialising, no probable/likely language without evidence-confidence qualifier."
    },
    "evidence": {
      "description": "Either an array of file references with sha256, or a single object with type=verbal for non-file evidence (e.g., a phone call).",
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Path relative to the incident root directory."
              },
              "sha256": {
                "type": "string",
                "description": "Lowercase hex sha256 digest, OR the literal string PENDING when the file has not yet been sealed.",
                "pattern": "^([a-f0-9]{64}|PENDING)$"
              },
              "line_range": {
                "type": "string",
                "pattern": "^[0-9]+(-[0-9]+)?$",
                "description": "Optional line numbers (start or start-end) within the cited file."
              },
              "quote": {
                "type": "string",
                "description": "Optional verbatim excerpt for forensic clarity."
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "summary"],
          "properties": {
            "type": {
              "const": "verbal"
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "witnesses": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
