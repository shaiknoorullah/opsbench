{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pnats.cloud/schemas/incident/rca.schema.json",
  "title": "RootCauseAnalysis",
  "description": "5-Whys / Apollo cause-effect RCA. Every why answer must cite at least one sha256-sealed evidence file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["incident_id", "why_chain", "final_root_cause", "evidence_attestation"],
  "properties": {
    "incident_id": {
      "type": "string",
      "pattern": "^INC-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"
    },
    "based_on_verdict_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "authored_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "why_chain": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer", "evidence_files"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 },
          "evidence_files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "type": "string" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "quote": { "type": "string" }
              }
            }
          },
          "contributing_factors": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "final_root_cause": {
      "type": "string",
      "minLength": 1
    },
    "contributing_factors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_attestation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
