{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules/**",
    ".git/**",
    "docs/.vitepress/cache/**",
    "docs/.vitepress/dist/**",
    "tools/plugin-build/output/**",
    "**/*.svg",
    "**/*.lock",
    "CHANGELOG.md"
  ],
  "dictionaries": ["en_US", "softwareTerms", "node", "bash", "filetypes"],
  "words": [
    "opsbench",
    "cntb",
    "Contabo",
    "OVH",
    "wireguard",
    "Longhorn",
    "Patroni",
    "Keeper",
    "Cedar",
    "dqlite",
    "Knative",
    "Cilium",
    "Calico",
    "Tempo",
    "Loki",
    "Falco",
    "Velociraptor",
    "PagerDuty",
    "Pydantic",
    "lefthook",
    "commitlint",
    "markdownlint",
    "yamllint",
    "shellcheck",
    "cspell",
    "ajv",
    "VitePress",
    "Docusaurus",
    "DevOps",
    "SRE",
    "subagent",
    "subagents",
    "kubeapiserver",
    "kubelet",
    "etcd",
    "tcpdump",
    "smartctl",
    "JBD2",
    "Spilo",
    "shaiknoorullah",
    "kubectl",
    "PreToolUse",
    "PostToolUse",
    "SubagentStop"
  ],
  "allowCompoundWords": true
}
