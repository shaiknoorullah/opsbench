{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pnats.cloud/schemas/incident/custody-entry.schema.json",
  "title": "CustodyEntry",
  "description": "One line in custody.log, expressed as JSON. The on-disk format is pipe-delimited (timestamp | collector | action | path | sha256=<hex>), but this schema governs the structured representation used by validators and analytics.",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp_utc", "collector", "action", "path", "sha256"],
  "properties": {
    "timestamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "collector": {
      "type": "string",
      "minLength": 1,
      "description": "Agent name or human operator identifier."
    },
    "action": {
      "type": "string",
      "enum": [
        "collected",
        "quarantined-stale",
        "sealed",
        "bundle-sealed",
        "quarantine-state-backup",
        "rolled-up",
        "verified"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "description": "Path relative to incident root."
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "round": { "type": "integer", "minimum": 1, "maximum": 5 },
    "source_family": {
      "type": "string",
      "enum": ["control_plane", "nodes", "observability", "storage", "network", "app_layer", "security", "platform"]
    }
  }
}
