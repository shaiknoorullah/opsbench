{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsbench.dev/schemas/autonomy-certificate.json",
  "title": "AutonomyCertificate",
  "description": "Queryable, revocable autonomy grant backed by eval evidence (PRD GOV-006, GOV-007; spec 01-schemas §4). No L3 grant exists without an active certificate.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tenant_id", "subject", "level", "evidence", "approved_by", "issued_at", "expires_at", "revocation"],
  "properties": {
    "id": { "type": "string", "pattern": "^cert_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "$ref": "common.json#/$defs/tenantId" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "scenario_class", "environment"],
      "properties": {
        "agent": { "$ref": "common.json#/$defs/spiffeId" },
        "scenario_class": { "type": "string", "description": "e.g. k8s.scale_out." },
        "environment": { "type": "string", "description": "e.g. prod-eu." }
      }
    },
    "level": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"],
      "description": "L0 observe · L1 suggest · L2 act-with-approval · L3 bounded-autonomous · L4 reserved/disabled."
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eval_runs", "thresholds", "window"],
      "properties": {
        "eval_runs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^evr_[0-9A-HJKMNP-TV-Z]{26}$" }
        },
        "thresholds": {
          "type": "object",
          "description": "Metric -> threshold expression, e.g. {\"rca_accuracy\": \">=0.85\"}.",
          "additionalProperties": { "type": "string" },
          "minProperties": 1
        },
        "window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to", "sample_size"],
          "properties": {
            "from": { "$ref": "common.json#/$defs/timestamp" },
            "to": { "$ref": "common.json#/$defs/timestamp" },
            "sample_size": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "approved_by": { "$ref": "common.json#/$defs/userId" },
    "issued_at": { "$ref": "common.json#/$defs/timestamp" },
    "expires_at": {
      "$ref": "common.json#/$defs/timestamp",
      "description": "Expiry triggers automatic reversion to the prior level."
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conditions", "status"],
      "properties": {
        "conditions": {
          "type": "array",
          "items": { "type": "string", "description": "e.g. error_budget_burn>1.0, eval_regression, manual." }
        },
        "status": { "type": "string", "enum": ["active", "revoked", "expired"] },
        "revoked_at": { "oneOf": [{ "$ref": "common.json#/$defs/timestamp" }, { "type": "null" }] },
        "revoked_reason": { "type": ["string", "null"] }
      }
    },
    "ledger_refs": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/ledgerRef" }
    }
  }
}
