{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsbench.dev/schemas/escalation-ladder.json",
  "title": "EscalationLadder",
  "description": "Platform-owned escalation ladder state (PRD ESC-001..ESC-003; spec 01-schemas §7). Vendors are delivery channels; terminal silence is unrepresentable.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tenant_id", "subject_ref", "target", "rungs", "state", "on_exhausted"],
  "properties": {
    "id": { "type": "string", "pattern": "^esc_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "$ref": "common.json#/$defs/tenantId" },
    "subject_ref": {
      "type": "string",
      "pattern": "^(apr|inc)_[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "The approval or incident this ladder escalates."
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolved_human", "roster_source", "resolved_at"],
      "properties": {
        "resolved_human": { "$ref": "common.json#/$defs/userId" },
        "roster_source": { "type": "string", "description": "e.g. pagerduty:schedule/P123." },
        "resolved_at": { "$ref": "common.json#/$defs/timestamp" }
      }
    },
    "rungs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["n", "channel", "timeout_s"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "channel": { "type": "string", "enum": ["slack", "teams", "push", "sms", "voice"] },
          "timeout_s": { "type": "integer", "minimum": 1 },
          "state": { "type": "string", "enum": ["pending", "fired", "acked", "timeout", "skipped_outage"] },
          "fired_at": { "$ref": "common.json#/$defs/timestamp" },
          "identity_assurance": { "type": "string", "enum": ["pin", "none"] }
        }
      }
    },
    "ack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by", "channel", "at"],
      "properties": {
        "by": { "$ref": "common.json#/$defs/userId" },
        "channel": { "$ref": "common.json#/$defs/surface" },
        "at": { "$ref": "common.json#/$defs/timestamp" },
        "evidence": {
          "type": "object",
          "description": "Channel-specific ack evidence. PIN values are never persisted, only verification results.",
          "additionalProperties": false,
          "properties": {
            "call_sid": { "type": "string" },
            "digits_hash": { "$ref": "common.json#/$defs/sha256" },
            "pin_verified": { "type": "boolean" },
            "attestation": { "type": "string", "description": "STIR/SHAKEN attestation level, e.g. A." }
          }
        }
      }
    },
    "state": { "type": "string", "enum": ["running", "acked", "exhausted"] },
    "on_exhausted": {
      "type": "array",
      "minItems": 1,
      "description": "Fallback contacts/groups (ESC-003). An empty list is a provisioning error.",
      "items": {
        "oneOf": [
          { "$ref": "common.json#/$defs/userId" },
          { "$ref": "common.json#/$defs/groupId" }
        ]
      }
    }
  }
}
