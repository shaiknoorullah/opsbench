---
interface Props {
  title?: string;
  description?: string;
  ogPath?: string;
}

const {
  title = 'opsbench — evidence, or it didn’t happen',
  description = 'opsbench is an open-source, forensic-grade agent toolkit for DevOps, SRE, platform, security and network teams. Verdict-blind investigation, SHA-256 evidence sealing, Cedar-gated mutations — for Claude Code and Codex CLI.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'opsbench',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Linux, macOS',
      description,
      license: 'https://opensource.org/licenses/MIT',
      url: 'https://github.com/shaiknoorullah/opsbench',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'Organization',
      name: 'opsbench',
      url: canonical.origin,
      sameAs: ['https://github.com/shaiknoorullah/opsbench'],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%230a0b0e'/%3E%3Ccircle cx='16' cy='16' r='8' fill='none' stroke='%23ffb454' stroke-width='2.5'/%3E%3Ccircle cx='16' cy='16' r='2.5' fill='%23ffb454'/%3E%3C/svg%3E"
    />
    <link rel="preload" href="/fonts/space-grotesk-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ibm-plex-mono-400.woff2" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {
      import.meta.env.PUBLIC_UMAMI_SRC && import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
        <script
          defer
          src={import.meta.env.PUBLIC_UMAMI_SRC}
          data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
